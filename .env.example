# ---- EIA API -----------------------------------------------------------
# Get a free key at https://www.eia.gov/opendata/register.php
# Leave blank to run in demo mode (deterministic synthetic data; the report
# is watermarked accordingly).
EIA_API_KEY=

# Balancing authorities to ingest (EIA respondent codes).
EIA_RESPONDENTS=ERCO,CISO,MISO

# Days of history on first run; later runs are incremental.
BACKFILL_DAYS=30
INCREMENTAL_LOOKBACK_HOURS=72

# ---- Postgres (compose creates this instance) --------------------------
POSTGRES_USER=dakota
POSTGRES_PASSWORD=dakota
POSTGRES_DB=energy
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Service URLs (host-side defaults; compose overrides internally) ---
DATABASE_URL=postgresql://dakota:dakota@localhost:5432/energy
ENRICHMENT_API_URL=http://localhost:8001
